{
  "expo": {
    "name": "kribb",
    "slug": "kribb",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/kribb.png",
    "scheme": "kribb",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.kribb"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/k-logo.png",
        "backgroundColor": "#FAF7F2"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.kribb"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/k-logo.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#FAF7F2"
        }
      ],
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
